{
  "name": "otakudb-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "import:anilist": "tsx src/modules/imports/anilist-import.ts",
    "search:reindex": "tsx src/modules/search/reindex.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@pothos/core": "^4.4.0",
    "@prisma/client": "^6.8.2",
    "argon2": "^0.41.1",
    "dataloader": "^2.2.3",
    "fastify": "^5.3.3",
    "graphql": "^16.11.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-yoga": "^5.13.4",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.49.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2",
      "esbuild"
    ]
  }
}
